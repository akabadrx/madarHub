// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id                 String    @id @default(cuid())
  name               String?
  phone              String
  source             String
  interest           String?
  suggestedPackageId String?
  suggestedPackage   Package?  @relation(fields: [suggestedPackageId], references: [id])
  status             String
  visitDate          DateTime?
  followUpDate       DateTime?
  paymentStatus      String    @default("Pending")
  amountPaid         Int       @default(0)
  notes              String?
  rawWhatsappSnippet String?
  aiSummary          String?
  aiConfidence       Float?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  payments        Payment[]
  visits          Visit[]
  interactions    Interaction[]
  pesapalPayments PesapalPayment[]

  @@index([status])
  @@index([followUpDate])
  @@index([phone])
}

model Payment {
  id            String    @id @default(cuid())
  leadId        String
  lead          Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  packageId     String?
  package       Package?  @relation(fields: [packageId], references: [id])
  amount        Int
  paymentMethod String
  paymentDate   DateTime  @default(now())
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([leadId])
  @@index([paymentDate])
}

model Visit {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  visitDate DateTime
  status    String   @default("Scheduled")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([visitDate])
}

model Package {
  id          String    @id @default(cuid())
  name        String
  slug        String?   @unique
  price       Int
  billingType String    @default("monthly")
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  leadsAsSuggested Lead[]
  payments         Payment[]
  pesapalPayments  PesapalPayment[]
}

model Interaction {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String
  content   String
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([createdAt])
}

model MessageTemplate {
  id        String   @id @default(cuid())
  title     String
  body      String
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Online checkout initiated from the public madarorbit.com site. Distinct from
// Payment (which records payments staff enter manually) because a Pesapal
// order exists before we know whether the customer actually paid.
model PesapalPayment {
  id                String    @id @default(cuid())
  merchantReference String    @unique
  packageId         String?
  package           Package?  @relation(fields: [packageId], references: [id])
  packageName       String
  amount            Int
  currency          String    @default("RWF")
  customerName      String
  customerEmail     String
  customerPhone     String?
  status            String    @default("PENDING") // PENDING | COMPLETED | FAILED
  pesapalTrackingId String?
  leadId            String?
  lead              Lead?     @relation(fields: [leadId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([customerEmail])
}
